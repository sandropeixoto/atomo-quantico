rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções Auxiliares
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isModerator() {
      return isSignedIn() && (getUserData().role == 'moderator' || getUserData().role == 'admin');
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isNotBlocked() {
      return isSignedIn() && getUserData().status != 'blocked';
    }

    match /entries/{entryId} {
      // Qualquer um pode ler posts públicos (ativos ou ocultos para mostrar o aviso).
      allow read: if resource.data.isPublic == true || (isSignedIn() && request.auth.uid == resource.data.authorId);
      
      // Apenas usuários não bloqueados podem criar posts.
      allow create: if isSignedIn() && isNotBlocked() 
                    && request.auth.uid == request.resource.data.authorId
                    && request.resource.data.likesCount == 0
                    && request.resource.data.commentsCount == 0;
      
      // Autores podem atualizar se não estiverem bloqueados.
      // Moderadores podem atualizar campos de status e moderação.
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.authorId && isNotBlocked() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'moderationReason', 'moderatedBy'])) ||
        (isModerator() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'moderationReason', 'moderatedBy'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount']) && isNotBlocked())
      );

      // Autores ou Moderadores podem deletar.
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isModerator());

      match /likes/{userId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked() && request.auth.uid == userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotBlocked() && request.auth.uid == request.resource.data.authorId;
        allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || isModerator());
      }
    }

    match /users/{userId} {
      allow read: if true;
      
      // Apenas o próprio usuário pode editar dados básicos.
      // Apenas Admins podem alterar role e status de bloqueio.
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'blockedReason'])) ||
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'blockedReason']))
      );
    }
  }
}
